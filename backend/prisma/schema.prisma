generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider     = "mysql"
  url          = env("DATABASE_URL")
  relationMode = "prisma"
}

model books {
  id Int @id
}

model classes {
  id Int @id
}

model lessons {
  id Int @id
}

model occupation {
  id Int @id
}

model professionals {
  cpf  BigInt  @id
  name String? @db.VarChar(45)
}

model students {
  cpf String @id @db.VarChar(45)
}
